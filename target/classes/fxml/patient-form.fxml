<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="ch.medisys.controller.PatientFormController"
      spacing="15" prefWidth="600" prefHeight="700">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    
    <Label text="Patientendetails" styleClass="form-title">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="15">
            <!-- Persönliche Daten -->
            <TitledPane text="Persönliche Daten" expanded="true">
                <GridPane hgap="10" vgap="10">
                    <Label text="Vorname:*" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="vornameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Nachname:*" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="nachnameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    
                    <Label text="Geburtsdatum:*" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <DatePicker fx:id="geburtsdatumPicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    
                    <Label text="Geschlecht:*" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <ComboBox fx:id="geschlechtCombo" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>
            
            <!-- Kontaktdaten -->
            <TitledPane text="Kontaktdaten">
                <GridPane hgap="10" vgap="10">
                    <Label text="Strasse:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="strasseField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="PLZ:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="plzField" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="100"/>
                    
                    <Label text="Ort:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="ortField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    
                    <Label text="Telefon:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="telefonField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    
                    <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>
            
            <!-- Versicherungsdaten -->
            <TitledPane text="Versicherungsdaten">
                <GridPane hgap="10" vgap="10">
                    <Label text="Versicherungsnr:*" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="versicherungsnummerField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Krankenkasse:*" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="krankenkasseField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>
            
            <!-- Notfallkontakt -->
            <TitledPane text="Notfallkontakt">
                <GridPane hgap="10" vgap="10">
                    <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="notfallkontaktNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Telefon:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="notfallkontaktTelefonField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                </GridPane>
            </TitledPane>
            
            <Label text="* Pflichtfelder" styleClass="hint-label"/>
        </VBox>
    </ScrollPane>
    
    <!-- Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Abbrechen" onAction="#handleCancel"/>
        <Button text="Speichern" onAction="#handleSave" styleClass="primary-button"/>
    </HBox>
    
</VBox>
