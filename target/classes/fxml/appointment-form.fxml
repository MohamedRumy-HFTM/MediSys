<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="ch.medisys.controller.AppointmentFormController"
      spacing="15" prefWidth="500" prefHeight="600">
    
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    
    <Label text="Termindetails" styleClass="form-title">
        <font>
            <Font size="18.0" />
        </font>
    </Label>
    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10">
            <GridPane hgap="10" vgap="10">
                <Label text="Patient:*" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="patientCombo" GridPane.columnIndex="1" GridPane.rowIndex="0" 
                          prefWidth="300"/>
                
                <Label text="Mitarbeiter:*" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <ComboBox fx:id="mitarbeiterCombo" GridPane.columnIndex="1" GridPane.rowIndex="1" 
                          prefWidth="300"/>
                
                <Label text="Datum:*" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <DatePicker fx:id="datumPicker" GridPane.columnIndex="1" GridPane.rowIndex="2" 
                            prefWidth="150"/>
                
                <Label text="Uhrzeit:*" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <ComboBox fx:id="uhrzeitCombo" prefWidth="100"/>
                    <Label text="Dauer (Min):"/>
                    <ComboBox fx:id="dauerCombo" prefWidth="80"/>
                </HBox>
                
                <Label text="Terminart:*" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="terminartCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" 
                          prefWidth="200"/>
                
                <Label text="Status:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <ComboBox fx:id="statusCombo" GridPane.columnIndex="1" GridPane.rowIndex="5" 
                          prefWidth="150"/>
                
                <Label text="Notizen:" GridPane.columnIndex="0" GridPane.rowIndex="6" 
                       alignment="TOP_LEFT"/>
                <TextArea fx:id="notizenArea" GridPane.columnIndex="1" GridPane.rowIndex="6" 
                          prefRowCount="3" wrapText="true"/>
                
                <columnConstraints>
                    <ColumnConstraints halignment="RIGHT" minWidth="100"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
            </GridPane>
            
            <Separator/>
            
            <!-- Verfügbarkeits-Check -->
            <VBox spacing="5">
                <Label text="Verfügbare Zeiten:" styleClass="field-label"/>
                <HBox spacing="10">
                    <Button text="Verfügbarkeit prüfen" onAction="#handleCheckAvailability"/>
                    <Label fx:id="availabilityLabel" textFill="GREEN"/>
                </HBox>
                <ScrollPane maxHeight="150" fitToWidth="true">
                    <FlowPane fx:id="availableSlotsPane" hgap="5" vgap="5"/>
                </ScrollPane>
            </VBox>
            
            <Label text="* Pflichtfelder" styleClass="hint-label"/>
        </VBox>
    </ScrollPane>
    
    <!-- Buttons unten fixiert -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Abbrechen" onAction="#handleCancel"/>
        <Button text="Speichern" onAction="#handleSave" styleClass="primary-button"/>
    </HBox>
    
</VBox>
